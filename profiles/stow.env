# shellcheck shell=sh disable=SC2034
# profiles/stow.env — the maintainer's box: nushell · XDG + GNU Stow dotfiles.
# Complements the user's ~/.config (read-only; never clobbered).
#
# AXIS 1 (config regime) ONLY — shell, prompt, yazi variant. It carries NO machine-
# specific paths and NO data/policy. The dbt project dir is resolved in lib/common.sh
# (per-workspace state -> $DBT_WS_DBT_DIR_DEFAULT env -> walk-up dbt_project.yml
# discovery -> $PWD), the duckdb path comes from the warehouse auto-derive, and the
# yazi client-id defaults in common.sh. So this profile ships ZERO personal data and
# is safe in a public, shared repo.

# shellcheck source=/dev/null
. "$DBT_WS_HOME/profiles/base.env"

SHELL_KIND="nu"
CONFIG_REGIME="xdg-stow"
PROMPT_GLYPH="❯"
YAZI_CONFIG_VARIANT="stow"

#!/bin/sh
# cide-jump [role] [--dry] — focus the IDE's OTHER role-workspace across windows/monitors.
# With no role it TOGGLES (editor <-> tools for the landscape-portrait layout). Resolves the
# target from the cide registry and derives its window live (so a reused/moved window still
# works). If the target is the editor and it's gone, regenerates it first. --dry prints the
# target without focusing. Bind this to a cmux.json keyboard shortcut for one-key monitor
# switching (cmux can't otherwise select the right workspace on the other monitor in one go).
set -eu

usage() { printf 'cide-jump [role] [label] [--dry]\n  Focus the IDE other role-workspace (default: toggle editor<->tools).\n  role=agent [label] focuses an agent surface across monitors.\n  -h, --help   show this help\n'; }
dry=""; role=""; label=""
for a in "$@"; do
  case "$a" in
    -h|--help) usage; exit 0 ;;
    --dry)     dry=1 ;;
    -*)        printf 'cide-jump: unknown option %s\n' "$a" >&2; exit 64 ;;
    *)         if [ -z "$role" ]; then role="$a"; else label="$a"; fi ;;
  esac
done

self="$0"
if [ -L "$self" ]; then self="$(readlink "$self")"; fi
DBT_WS_HOME="${DBT_WS_HOME:-$(cd "$(dirname "$self")/.." && pwd)}"
# shellcheck source=/dev/null
. "$DBT_WS_HOME/lib/common.sh"
# shellcheck source=/dev/null
. "$DBT_WS_HOME/lib/cide-editor.sh"

# Focus a live agent surface (role=agent). Agents are surface-grained, so this path
# uses cmux's native session store + cide labels (not the workspace registry): pick by
# label (or the most-recently-active agent), then focus its window/workspace/tab.
agent_jump() {  # [label]
  _want="${1:-}"; _live="$(cide_live_uuids)"; _members="$(cide_member_workspaces)"
  _t="$(printf '\t')"; _bs=""; _bw=""; _bu=-1; _blabel=""
  while IFS="$_t" read -r _surf _ws _upd _slabel; do
    [ -n "$_surf" ] || continue
    printf '%s\n' "$_live" | grep -qiF "$_surf" || continue   # live surfaces only
    printf '%s\n' "$_members" | grep -qiF "$_ws" || continue  # this cide instance only
    _clabel="$(cide_agent_label_of "$_surf")"; _lab="${_clabel:-$_slabel}"
    _u="${_upd:-0}"
    if [ -n "$_want" ]; then
      if [ "$_lab" = "$_want" ]; then _bs="$_surf"; _bw="$_ws"; _blabel="$_lab"; break; fi
    else
      if [ "$_u" -gt "$_bu" ] 2>/dev/null; then _bu="$_u"; _bs="$_surf"; _bw="$_ws"; _blabel="$_lab"; fi
    fi
  done <<EOF
$(jq -r '.sessions | to_entries[] | .value |
  [ .surfaceId, .workspaceId, ((.updatedAt // 0) | floor | tostring),
    ( (.launchCommand.arguments // []) as $a | (($a|index("--name")) // ($a|index("-n"))) as $i | if $i then ($a[$i+1] // "") else "" end )
  ] | @tsv' "${CIDE_AGENT_STORE:-$HOME/.cmuxterm/claude-hook-sessions.json}" 2>/dev/null)
EOF
  [ -n "$_bs" ] || { echo "cide-jump: no live agent${_want:+ \"$_want\"} in scope — launch one with 'cide-agent'." >&2; exit 1; }
  _nm_disp="${_blabel:-$_bs}"
  _twin="$(cide_ws_window "$_bw" 2>/dev/null || true)"
  if [ -n "$dry" ]; then echo "cide-jump: -> agent $_nm_disp  win=${_twin:-?} ws=$_bw surface=$_bs"; exit 0; fi
  # If we're already ON the agent's surface, focusing is a silent no-op — say so instead
  # (this is what made a same-surface 'jump' look like it did nothing).
  _cur_sf="$(cide_cur_surface 2>/dev/null || true)"
  if [ -n "$_cur_sf" ] && [ "$(printf '%s' "$_bs" | tr 'a-f' 'A-F')" = "$_cur_sf" ]; then
    echo "cide-jump: already on agent $_nm_disp ($_bs)."
    exit 0
  fi
  [ -n "$_twin" ] && cmux focus-window --window "$_twin" >/dev/null 2>&1 || true
  cmux select-workspace --workspace "$_bw" >/dev/null 2>&1 || true
  # focus the agent's surface (tab) — focus-panel selects a surface within its pane,
  # works same-pane AND cross-window; UUIDs resolve globally.
  if cmux focus-panel --panel "$_bs" --workspace "$_bw" >/dev/null 2>&1; then
    echo "cide-jump -> agent $_nm_disp ($_bs)"
    exit 0
  fi
  echo "cide-jump: resolved agent $_nm_disp ($_bs) but focus failed" >&2
  exit 1
}

name="$(cide_ide_name)"
if [ "$role" = agent ]; then agent_jump "$label"; fi

# Currently-focused workspace -> its role (if registered).
fid="$(cmux identify --json 2>/dev/null || true)"
fws="$(printf '%s' "$fid" | grep -oE 'workspace:[0-9]+' | head -1)"
cur="$(cide_registry_role_of_ws "$name" "$fws" 2>/dev/null || true)"

# Target role: explicit arg, else the other of the editor/tools pair.
if [ -z "$role" ]; then
  if [ "$cur" = "editor" ]; then role="tools"; else role="editor"; fi
fi

refs="$(cide_registry_get "$name" "$role" 2>/dev/null || true)"
tws="$(printf '%s' "$refs" | awk '{print $1}')"
tpane="$(printf '%s' "$refs" | awk '{print $2}')"

# Resolve / self-heal the target.
if [ -z "$tws" ] || ! cmux tree --workspace "$tws" >/dev/null 2>&1; then
  if [ "$role" = "editor" ]; then
    [ -n "$dry" ] && { echo "cide-jump: editor missing -> would regenerate"; exit 0; }
    cide_regen_editor || { echo "cide-jump: editor unavailable" >&2; exit 1; }
    tws="$EDITOR_WS"; tpane="$EDITOR_PANE"
  else
    echo "cide-jump: role '$role' not registered/alive — run 'cide-set-role $role' in that workspace." >&2
    exit 1
  fi
fi

twin="$(cide_ws_window "$tws" 2>/dev/null || true)"
if [ -n "$dry" ]; then
  echo "cide-jump: from=${cur:-?} -> $role   window=${twin:-?} ws=$tws pane=${tpane:-?}"
  exit 0
fi
[ -n "$twin" ] && cmux focus-window --window "$twin" >/dev/null 2>&1 || true
cmux select-workspace --workspace "$tws" >/dev/null 2>&1 || true
[ -n "$tpane" ] && cmux focus-pane --pane "$tpane" --workspace "$tws" >/dev/null 2>&1 || true
echo "cide-jump -> $role ($tws${tpane:+ $tpane})"

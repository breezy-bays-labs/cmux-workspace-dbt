#!/bin/sh
# cide-space — IDE spaces: named, lifecycle-managed containers that cide CREATES FRESH
# from the cide.toml [ide].layout preset (#21). Each space owns its OWN cmux workspaces
# (disjoint by construction — no overlap with your live IDE, so close/rm never touch
# another space). The repo-derived instance is the implicit DEFAULT space.
#
#   cide-space [ls]            list spaces (status, members, last active); * = active
#   cide-space new <name>      build a fresh space from the layout preset; make it active
#   cide-space new <name> --dry  print the window plan + layout JSON without creating
#   cide-space open <name|id>  REOPEN a closed space — rebuild its windows from the stored
#                              layout AND resume any agent conversation captured at close
#   cide-space use <name|id>   focus the space (and make it active); 'default' = repo
#   cide-space current         show the active space
#   cide-space close <name|id> close the space's workspaces; KEEP the record + history
#   cide-space rm <name|id>    close + purge the record (confirm unless -f)
#
# Build (new/open share one executor, _instantiate): resolve a window per layout role
# (reusing an existing same-orientation window, else a fresh one — physical-monitor
# placement isn't CLI-controllable, so a new window lands on the main monitor: drag once),
# then `cmux new-workspace --layout` instantiates that window's panes/surfaces. Each
# created workspace is stamped with a cide:spaces=<id> description tag at birth, so the
# space resolves live (and after a restart) without depending on volatile UUIDs.
#
# Agent conversation-resume (the self-heal prize): `close` snapshots each member
# workspace's live claude session (checkpoint = the cmux store's sessionId) into
# spaces/<id>/agents BEFORE closing; `open` reads it back and relaunches the agent slot as
# `claude --name <label> --resume <checkpoint>` (falling back to a hint shell if the
# transcript is gone), so reopening a space continues the conversation where it left off.
set -eu

self="$0"
if [ -L "$self" ]; then self="$(readlink "$self")"; fi
DBT_WS_HOME="${DBT_WS_HOME:-$(cd "$(dirname "$self")/.." && pwd)}"
# shellcheck source=/dev/null
. "$DBT_WS_HOME/lib/common.sh"
# shellcheck source=/dev/null
. "$DBT_WS_HOME/lib/cide-editor.sh"
# shellcheck source=/dev/null
. "$DBT_WS_HOME/lib/cide-layout.sh"

usage() {
  cat <<'EOF'
cide-space — IDE spaces (fresh, self-contained containers built from the layout preset)
  cide-space [ls]              list spaces (status, members, last active); * = active
  cide-space new <name>        build a fresh space from the layout; make it active
  cide-space new <name> --dry  print the window plan + layout JSON, create nothing
  cide-space open <name|id>    reopen a closed space (rebuild + resume its agent)
  cide-space open <name|id> --dry  print the reopen plan (incl. agent resume vs fallback)
  cide-space use <name|id>     focus the space (active); 'default' returns to repo scope
  cide-space current           show the active space
  cide-space close <name|id>   close the space's workspaces; keep the record + history
  cide-space rm <name|id> [-f]  close + purge the record (confirm unless -f)
  -h, --help                   show this help
EOF
}

_t="$(printf '\t')"

_since() {
  awk -v s="${1:-0}" 'BEGIN{
    if (s<0) s=0
    if      (s<60)    printf "%ds", s
    else if (s<3600)  printf "%dm", int(s/60)
    else if (s<86400) printf "%dh", int(s/3600)
    else              printf "%dd", int(s/86400)
  }'
}

_slug() {
  printf '%s' "$1" | tr '[:upper:]' '[:lower:]' \
    | sed -e 's/[^a-z0-9]\{1,\}/-/g' -e 's/^-//' -e 's/-$//'
}

# resolve <name|id> -> id (matches meta id OR name field); prints nothing if absent
_resolve() {  # <name|id>
  [ -d "$CIDE_SPACES" ] || return 0
  for _rd in "$CIDE_SPACES"/*/; do
    [ -f "$_rd/meta" ] || continue
    _rid="$(cut -d'|' -f1 "$_rd/meta")"; _rnm="$(cut -d'|' -f2 "$_rd/meta")"
    if [ "$1" = "$_rid" ] || [ "$1" = "$_rnm" ]; then printf '%s' "$_rid"; return 0; fi
  done
  return 0
}

_field() { cut -d'|' -f"$2" "$CIDE_SPACES/$1/meta" 2>/dev/null; }  # <id> <fieldnum>

# Resolve a window for an orientation. Prints "<window-ref>\t<defws-to-drop-or-empty>".
# reuse mode opens IN an existing same-orientation window (right monitor, no drag); else
# a fresh window (main monitor — drag once), whose default Terminal workspace we drop
# AFTER creating ours (so the window is never momentarily empty).
_resolve_window() {  # <orientation>
  _omw="$(cide_toml_get ide on_missing_window)"; _omw="${_omw:-reuse}"
  _w=""
  [ "$_omw" = reuse ] && _w="$(cide_find_window "$1" 2>/dev/null || true)"
  if [ -n "$_w" ]; then printf '%s%s' "$_w" "$_t"; return 0; fi
  _o="$(cmux new-window 2>&1)" || return 1
  _w="$(printf '%s' "$_o" | grep -oE 'window:[0-9]+' | head -1)"
  [ -n "$_w" ] || return 1
  _defws="$(cmux tree --window "$_w" 2>/dev/null | grep -oE 'workspace:[0-9]+' | head -1)"
  printf '%s%s%s' "$_w" "$_t" "${_defws:-}"
}

# ref -> uuid (uppercased)
_ws_uuid() {  # <workspace-ref>
  cmux rpc workspace.list '{}' 2>/dev/null \
    | jq -r --arg r "$1" '(.workspaces // .)[] | select(.ref==$r) | .id' 2>/dev/null \
    | head -1 | tr 'a-f' 'A-F'
}

# Pretty-print a window plan (--dry): per-window role/orientation + per-pane surface names.
_print_plan() {  # <plan-tsv>
  printf '%s\n' "$1" | while IFS="$_t" read -r _role _orient _json; do
    [ -n "$_role" ] || continue
    printf '\n  window: role=%s  orientation=%s\n' "$_role" "$_orient"
    printf '%s' "$_json" | jq -r '[.. | .surfaces? // empty | (map(.name) | join(", "))]
      | to_entries[] | "    pane \(.key+1): \(.value)"' 2>/dev/null
  done
}

# Compose the agent-slot launch command for `open` from the checkpoint captured at close
# (spaces/<id>/agents = role|label|checkpoint|transcriptPath). Prints
# "claude --name '<label>' --resume <checkpoint> [args...]" for cide_layout_plan's agent
# override — or NOTHING (so the slot falls back to the hint shell) when there's no record
# or the transcript is gone. v1 = one agent slot: the first restorable row wins.
_resume_agent_cmd() {  # <space-id>
  _raf="$CIDE_SPACES/$1/agents"
  [ -s "$_raf" ] || return 0
  while IFS='|' read -r _arole _alabel _ackpt _atx; do
    [ -n "$_ackpt" ] || continue
    if [ -n "$_atx" ] && [ ! -f "$_atx" ]; then continue; fi   # stale transcript -> hint shell
    _rcmd="$(cide_toml_get agents.claude command)";    _rcmd="${_rcmd:-claude}"
    _rnflag="$(cide_toml_get agents.claude name_flag)"; _rnflag="${_rnflag:---name}"
    _rrflag="$(cide_toml_get agents.claude resume_flag)"; _rrflag="${_rrflag:---resume}"
    _rargs=""                                                   # configured args (parity with cide-agent)
    _raw="$(cide_toml_get agents.claude args)"; _inner="${_raw#[}"; _inner="${_inner%]}"
    _OIFS=$IFS; IFS=','
    for _a in $_inner; do
      _a="$(printf '%s' "$_a" | sed -e 's/^[[:space:]]*//' -e 's/[[:space:]]*$//' -e 's/^"//' -e 's/"$//')"
      [ -n "$_a" ] && _rargs="$_rargs $_a"
    done
    IFS=$_OIFS
    printf "%s %s '%s' %s %s%s" "$_rcmd" "$_rnflag" "$_alabel" "$_rrflag" "$_ackpt" "$_rargs"
    return 0
  done < "$_raf"
  return 0
}

# Snapshot any agent (claude) sessions living inside a space's member workspaces into
# spaces/<id>/agents (role|label|checkpoint|transcriptPath) so `open` can --resume them.
# Members are resolved LIVE by the cide:spaces tag (workspace.list) — NOT the stored
# members UUIDs, which die across a cmux restart; resolving by tag is what makes capture
# survive the very restart this feature exists for. For each live member it reads the
# session store and matches store.surfaceId ∈ that workspace's live surfaces; only
# restorable sessions are recorded. Overwrites the file (latest close wins); leaves a
# prior file untouched if nothing restorable is found. Call BEFORE closing the workspaces
# (the sessions must still be live to read their surfaces).
_capture_agents() {  # <space-id>
  _caid="$1"; _cadir="$CIDE_SPACES/$_caid"
  [ -f "$CIDE_AGENT_STORE" ] || return 0
  _tmp="$_cadir/agents.tmp"; : > "$_tmp"
  # live members as UUID<TAB>role (role from the workspace's cide:spaces=<id>;role=<role>
  # description tag, same scan idiom as cide_space_members; id upper-cased to match store).
  cmux rpc workspace.list '{}' 2>/dev/null \
    | jq -r --arg sid "$_caid" '(.workspaces // .)[]
        | select(((.description // "") | [scan("(^|;)cide:spaces=([^;]*)")] | (.[-1] // [""]) | .[-1]
                  | split(",") | index($sid)) != null)
        | [ (.id | ascii_upcase),
            ((.description // "") | [scan("(^|;)role=([^;]*)")] | (.[-1] // [""]) | .[-1]) ] | @tsv' \
        2>/dev/null \
    | while IFS="$_t" read -r _mws _mrole; do
        [ -n "$_mws" ] || continue
        _surfs="$(cmux tree --workspace "$_mws" --id-format uuids 2>/dev/null \
                  | grep -oiE '[0-9a-f]{8}-[0-9a-f]{4}-[0-9a-f]{4}-[0-9a-f]{4}-[0-9a-f]{12}' \
                  | tr 'a-f' 'A-F' | sort -u)"
        [ -n "$_surfs" ] || continue
        jq -r '.sessions | to_entries[] | .value
               | select((.isRestorable // false) == true)
               | [ .surfaceId, .sessionId, (.transcriptPath // ""),
                   ( (.launchCommand.arguments // []) as $a
                     | (($a | index("--name")) // ($a | index("-n"))) as $i
                     | if $i then ($a[$i+1] // "") else "" end ) ] | @tsv' \
            "$CIDE_AGENT_STORE" 2>/dev/null \
          | while IFS="$_t" read -r _ssurf _sckpt _stx _slabel; do
              [ -n "$_sckpt" ] || continue
              printf '%s\n' "$_surfs" | grep -qiF "$_ssurf" || continue
              _lbl="${_slabel:-$(cide_agent_label_of "$_ssurf")}"; _lbl="${_lbl:-claude}"
              printf '%s|%s|%s|%s\n' "${_mrole:-agent}" "$_lbl" "$_sckpt" "$_stx" >> "$_tmp"
            done
      done
  if [ -s "$_tmp" ]; then mv "$_tmp" "$_cadir/agents"; else rm -f "$_tmp"; fi
}

# Build a space's cmux workspaces from its layout (shared by new + open). Rewrites
# spaces/<id>/members (role|ws-uuid|cwd) and prints the window count on stdout. When the
# space has a captured agent checkpoint (open path), the agent slot relaunches as a
# claude --resume; otherwise it's a hint shell (new path). Each workspace is stamped
# cide:spaces=<id>;role=<role> at birth.
_instantiate() {  # <id> <name> <layout> <cwd>
  _ins_id="$1"; _ins_name="$2"; _ins_layout="$3"; _ins_cwd="$4"
  _ins_dir="$CIDE_SPACES/$_ins_id"
  _ins_agentcmd="$(_resume_agent_cmd "$_ins_id")"
  _ins_plan="$(cide_layout_plan "$_ins_layout" "$_ins_agentcmd")"
  : > "$_ins_dir/members"

  _first=1
  printf '%s\n' "$_ins_plan" | while IFS="$_t" read -r _role _orient _json; do
    [ -n "$_role" ] || continue
    _wr="$(_resolve_window "$_orient")" || { echo "cide-space: could not get a $_orient window for role $_role" >&2; continue; }
    _win="${_wr%%"$_t"*}"; _defws="${_wr#*"$_t"}"
    _focus=false; [ "$_first" -eq 1 ] && _focus=true
    _out="$(cmux new-workspace --window "$_win" --name "$_ins_name" \
              --description "cide:spaces=$_ins_id;role=$_role" --cwd "$_ins_cwd" \
              --layout "$_json" --focus "$_focus" 2>&1)" || { echo "cide-space: failed to create $_role workspace" >&2; continue; }
    _wref="$(printf '%s' "$_out" | grep -oE 'workspace:[0-9]+' | head -1)"
    [ -n "$_defws" ] && cmux close-workspace --workspace "$_defws" --window "$_win" >/dev/null 2>&1 || true
    _wid="$(_ws_uuid "$_wref")"
    printf '%s|%s|%s\n' "$_role" "${_wid:-$_wref}" "$_ins_cwd" >> "$_ins_dir/members"
    _first=0
  done

  awk 'NF' "$_ins_dir/members" 2>/dev/null | wc -l | tr -d ' '
}

# --- new: build a fresh space from the layout preset --------------------------
cmd_new() {
  _name=""; _dry=0
  for a in "$@"; do
    case "$a" in --dry) _dry=1 ;; -*) echo "cide-space: unknown option $a" >&2; exit 64 ;; *) [ -z "$_name" ] && _name="$a" ;; esac
  done
  [ -n "$_name" ] || { echo "usage: cide-space new <name> [--dry]" >&2; exit 64; }
  case "$_name" in *"|"*) echo "cide-space: name must not contain '|'." >&2; exit 64 ;; esac

  _layout="$(cide_toml_get ide layout)"; _layout="${_layout:-landscape-portrait}"
  _cwd="$DBT_WS_HOME"

  if [ "$_dry" -eq 1 ]; then
    printf 'cide-space (DRY) — would build "%s" from layout "%s" (cwd %s):\n' "$_name" "$_layout" "$_cwd"
    _print_plan "$(cide_layout_plan "$_layout")"
    return 0
  fi

  if [ -n "$(_resolve "$_name")" ]; then
    echo "cide-space: a space named/id '$_name' already exists (names are unique)." >&2; exit 1
  fi
  _slugbase="$(_slug "$_name")"; [ -n "$_slugbase" ] || _slugbase="space"
  _id="${_slugbase}-$(date +%s)"
  while [ -d "$CIDE_SPACES/$_id" ]; do _id="${_slugbase}-$(date +%s)-$$"; done
  _dir="$CIDE_SPACES/$_id"; mkdir -p "$_dir"
  printf '%s|%s|%s|%s|%s\n' "$_id" "$_name" open "$(date +%s)" "$_layout" > "$_dir/meta"

  cide_ensure_claude_hooks   # ready capture from birth, even if the user types bare `claude`
  _made="$(_instantiate "$_id" "$_name" "$_layout" "$_cwd")"
  printf '%s|%s|%s\n' "$(date +%s)" created "windows=$_made" >> "$_dir/history"
  mkdir -p "$CIDE_STATE"; printf '%s' "$_id" > "$CIDE_CURRENT_SPACE"

  printf 'cide-space: built "%s" (id %s) — %s window(s) from layout "%s"; now active.\n' "$_name" "$_id" "$_made" "$_layout"
  printf '  use "cide-space use default" to return to the repo scope; "cide-space rm %s" to remove it.\n' "$_name"
}

# --- open: REOPEN a closed space — rebuild windows + resume captured agent(s) --
cmd_open() {
  _arg=""; _dry=0
  for a in "$@"; do
    case "$a" in --dry) _dry=1 ;; -*) echo "cide-space: unknown option $a" >&2; exit 64 ;; *) [ -z "$_arg" ] && _arg="$a" ;; esac
  done
  [ -n "$_arg" ] || { echo "usage: cide-space open <name|id> [--dry]" >&2; exit 64; }
  _id="$(_resolve "$_arg")"; [ -n "$_id" ] || { echo "cide-space: no space '$_arg' (try 'cide-space ls')." >&2; exit 1; }
  _name="$(_field "$_id" 2)"
  _layout="$(_field "$_id" 5)"; _layout="${_layout:-landscape-portrait}"
  # spaces are repo-rooted; preserve whatever cwd the space was built with.
  _cwd="$(cut -d'|' -f3 "$CIDE_SPACES/$_id/members" 2>/dev/null | awk 'NF' | head -1)"; _cwd="${_cwd:-$DBT_WS_HOME}"

  if [ "$_dry" -eq 1 ]; then
    printf 'cide-space (DRY) — would reopen "%s" (id %s) from layout "%s" (cwd %s):\n' "$_name" "$_id" "$_layout" "$_cwd"
    _ac="$(_resume_agent_cmd "$_id")"
    if [ -n "$_ac" ]; then printf '  agent slot: RESUME -> %s\n' "$_ac"
    else printf '  agent slot: fresh hint shell (no restorable checkpoint captured)\n'; fi
    _print_plan "$(cide_layout_plan "$_layout" "$_ac")"
    return 0
  fi

  # already open? (live members exist) -> redirect to `use`, don't double-build.
  _live=0
  for _ws in $(cide_space_members "$_id"); do [ -n "$_ws" ] && _live=$(( _live + 1 )); done
  if [ "$_live" -gt 0 ]; then
    printf 'cide-space: "%s" is already open (%s live workspace(s)); focus it with "cide-space use %s".\n' "$_name" "$_live" "$_name"
    return 0
  fi

  cide_ensure_claude_hooks   # so a layout-launched claude --resume is captured for NEXT close
  _ac="$(_resume_agent_cmd "$_id")"   # non-empty iff a restorable checkpoint will be resumed
  _made="$(_instantiate "$_id" "$_name" "$_layout" "$_cwd")"
  _tmp="$CIDE_SPACES/$_id/meta.tmp"
  awk -F'|' 'BEGIN{OFS="|"} {$3="open"; print}' "$CIDE_SPACES/$_id/meta" > "$_tmp" && mv "$_tmp" "$CIDE_SPACES/$_id/meta"
  printf '%s|%s|%s\n' "$(date +%s)" opened "windows=$_made" >> "$CIDE_SPACES/$_id/history"
  mkdir -p "$CIDE_STATE"; printf '%s' "$_id" > "$CIDE_CURRENT_SPACE"

  printf 'cide-space: reopened "%s" (id %s) — %s window(s) from layout "%s"; now active.\n' "$_name" "$_id" "$_made" "$_layout"
  if [ -n "$_ac" ]; then printf '  agent conversation resumed (claude --resume from the checkpoint captured at close).\n'; fi
}

# --- ls / current -------------------------------------------------------------
cmd_ls() {
  _cur="$(cide_current_space)"
  _hdr='%-2s %-22s %-16s %-7s %-8s %s\n'
  # shellcheck disable=SC2059
  printf "$_hdr" "" "ID" "NAME" "STATUS" "WINDOWS" "LAST"
  _dmk=" "; [ -z "$_cur" ] && _dmk="*"
  # shellcheck disable=SC2059
  printf "$_hdr" "$_dmk" "default" "$(cide_ide_name)" "open" "-" "live"
  [ -d "$CIDE_SPACES" ] || return 0
  _now="$(date +%s)"
  for _d in "$CIDE_SPACES"/*/; do
    [ -f "$_d/meta" ] || continue
    _id="$(cut -d'|' -f1 "$_d/meta")"; _nm="$(cut -d'|' -f2 "$_d/meta")"; _st="$(cut -d'|' -f3 "$_d/meta")"
    _mc="$(awk 'NF' "$_d/members" 2>/dev/null | wc -l | tr -d ' ')"
    _last="-"
    if [ -s "$_d/history" ]; then
      _ts="$(tail -1 "$_d/history" | cut -d'|' -f1)"
      case "$_ts" in *[!0-9]*|'') _last="-" ;; *) _last="$(_since "$(( _now - _ts ))")" ;; esac
    fi
    _mk=" "; [ "$_id" = "$_cur" ] && _mk="*"
    # shellcheck disable=SC2059
    printf "$_hdr" "$_mk" "$_id" "$_nm" "$_st" "$_mc" "$_last"
  done
}

cmd_current() {
  _cur="$(cide_current_space)"
  if [ -z "$_cur" ]; then echo "(default: $(cide_ide_name) — repo scope)"; return 0; fi
  printf '%s (%s) — status %s\n' "$(_field "$_cur" 2)" "$_cur" "$(_field "$_cur" 3)"
}

# --- use: focus the space + make it active ------------------------------------
cmd_use() {
  _arg="${1:-}"; [ -n "$_arg" ] || { echo "usage: cide-space use <name|id|default>" >&2; exit 64; }
  if [ "$_arg" = default ] || [ "$_arg" = "-" ]; then
    rm -f "$CIDE_CURRENT_SPACE" 2>/dev/null || true
    echo "cide-space: active space -> default ($(cide_ide_name) / repo scope)."
    return 0
  fi
  _id="$(_resolve "$_arg")"; [ -n "$_id" ] || { echo "cide-space: no space '$_arg' (try 'cide-space ls')." >&2; exit 1; }
  mkdir -p "$CIDE_STATE"; printf '%s' "$_id" > "$CIDE_CURRENT_SPACE"
  _n=0
  for _ws in $(cide_space_members "$_id"); do
    [ -n "$_ws" ] || continue
    _win="$(cide_ws_window "$_ws" 2>/dev/null || true)"
    [ -n "$_win" ] && cmux focus-window --window "$_win" >/dev/null 2>&1 || true
    cmux select-workspace --workspace "$_ws" >/dev/null 2>&1 || true
    _n=$(( _n + 1 ))
  done
  printf 'cide-space: active space -> %s (%s); focused %s live workspace(s).\n' "$(_field "$_id" 2)" "$_id" "$_n"
  [ "$_n" -eq 0 ] && printf '  (no live workspaces — it may be closed; reopen with "cide-space open %s".)\n' "$(_field "$_id" 2)" || true
}

# close the space's OWN live workspaces (by its cide:spaces tag), except the caller's
# own (closing the terminal you're in would kill this command). Prints the count.
_close_members() {  # <space-id>
  _self="$(printf '%s' "${CMUX_WORKSPACE_ID:-}" | tr 'a-f' 'A-F')"
  _cn=0
  for _ws in $(cide_space_members "$1"); do
    [ -n "$_ws" ] || continue
    if [ -n "$_self" ] && [ "$_ws" = "$_self" ]; then
      echo "cide-space: keeping current workspace $_ws (you're in it)." >&2; continue
    fi
    cmux close-workspace --workspace "$_ws" >/dev/null 2>&1 || echo "cide-space: warning — could not close $_ws" >&2
    _cn=$(( _cn + 1 ))
  done
  printf '%s' "$_cn"
}

cmd_close() {
  _arg="${1:-}"; [ -n "$_arg" ] || { echo "usage: cide-space close <name|id>" >&2; exit 64; }
  _id="$(_resolve "$_arg")"; [ -n "$_id" ] || { echo "cide-space: no space '$_arg'." >&2; exit 1; }
  _capture_agents "$_id"   # snapshot live agent checkpoints BEFORE closing (so open can resume)
  _ac="$(awk 'NF' "$CIDE_SPACES/$_id/agents" 2>/dev/null | wc -l | tr -d ' ')"
  _n="$(_close_members "$_id")"
  _tmp="$CIDE_SPACES/$_id/meta.tmp"
  awk -F'|' 'BEGIN{OFS="|"} {$3="closed"; print}' "$CIDE_SPACES/$_id/meta" > "$_tmp" && mv "$_tmp" "$CIDE_SPACES/$_id/meta"
  printf '%s|%s|%s\n' "$(date +%s)" closed "closed=$_n;agents=${_ac:-0}" >> "$CIDE_SPACES/$_id/history"
  if [ "$(cide_current_space)" = "$_id" ]; then rm -f "$CIDE_CURRENT_SPACE" 2>/dev/null || true; fi
  printf 'cide-space: closed "%s" — %s workspace(s) closed; record + history kept.\n' "$(_field "$_id" 2)" "$_n"
  if [ "${_ac:-0}" -gt 0 ]; then printf '  captured %s agent checkpoint(s) — "cide-space open %s" resumes the conversation.\n' "$_ac" "$(_field "$_id" 2)"; fi
}

cmd_rm() {
  _force=0; _arg=""
  for a in "$@"; do
    case "$a" in -f|--force) _force=1 ;; -*) echo "cide-space: unknown option $a" >&2; exit 64 ;; *) _arg="$a" ;; esac
  done
  [ -n "$_arg" ] || { echo "usage: cide-space rm <name|id> [-f]" >&2; exit 64; }
  _id="$(_resolve "$_arg")"; [ -n "$_id" ] || { echo "cide-space: no space '$_arg'." >&2; exit 1; }
  _nm="$(_field "$_id" 2)"
  if [ "$_force" -ne 1 ]; then
    if [ -t 0 ]; then
      printf 'cide-space: remove "%s" (%s)? closes its workspaces and purges record + history. [y/N] ' "$_nm" "$_id"
      read -r _ans || _ans=""
      case "$_ans" in y|Y|yes|YES) : ;; *) echo "cide-space: aborted."; return 0 ;; esac
    else
      echo "cide-space: refusing to rm '$_nm' in a non-interactive shell without -f (it closes workspaces + purges the record)." >&2
      exit 1
    fi
  fi
  _n="$(_close_members "$_id")"
  if [ "$(cide_current_space)" = "$_id" ]; then rm -f "$CIDE_CURRENT_SPACE" 2>/dev/null || true; fi
  rm -rf "${CIDE_SPACES:?}/${_id:?}" 2>/dev/null || true
  printf 'cide-space: removed "%s" (%s) — %s workspace(s) closed; record purged.\n' "$_nm" "$_id" "$_n"
}

sub="${1:-ls}"
[ "$#" -gt 0 ] && shift || true
case "$sub" in
  -h|--help)   usage; exit 0 ;;
  new)         cmd_new "$@" ;;
  open|reopen) cmd_open "$@" ;;
  ls|list)     cmd_ls "$@" ;;
  use|switch)  cmd_use "$@" ;;
  current)     cmd_current "$@" ;;
  close)       cmd_close "$@" ;;
  rm|remove)   cmd_rm "$@" ;;
  -*)          echo "cide-space: unknown option $sub" >&2; usage >&2; exit 64 ;;
  *)           echo "cide-space: unknown subcommand $sub (try: new ls use current close rm)" >&2; exit 64 ;;
esac

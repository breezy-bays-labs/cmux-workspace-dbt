# Per-workspace runtime state ($CMUX_WORKSPACE_ID-keyed); never committed.
state/

# Local overrides + macOS cruft
*.local
.DS_Store
err.tmp

# Session scaffolding (pipeline focus notes etc.); never committed to the public repo
.claude/

# Yazi plugins/flavors are ya-pkg-managed (versions pinned in each package.toml);
# reproduce with `ya pkg install` rather than vendoring the third-party code.
config/yazi/*/plugins/
config/yazi/*/flavors/

# Per-workspace runtime state ($CMUX_WORKSPACE_ID-keyed); never committed.
state/

# Local overrides + macOS cruft
*.local
.DS_Store
err.tmp

# Fetched upstream cmux docs snapshot (third-party content; cite URLs instead of vendoring)
docs/vision/research/.tmp-cmux-docs/

# Session scaffolding (pipeline focus notes etc.); never committed to the public repo
.claude/

# Yazi plugins + UPSTREAM flavors are ya-pkg-managed (pinned in each package.toml);
# reproduce with `ya pkg install` rather than vendoring third-party code.
config/yazi/*/plugins/
config/yazi/*/flavors/*
# ...but DO commit our hand-written cide flavors (no upstream to reproduce from):
!config/yazi/*/flavors/tokyonight.yazi/
!config/yazi/*/flavors/nord.yazi/
!config/yazi/*/flavors/gruvbox.yazi/
